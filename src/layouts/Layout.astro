---
import CyberBackground from '../components/CyberBackground.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'John Garcia — Full-Stack Developer',
  description = 'Portafolio de John Garcia. Desarrollador Full-Stack, Analista TI y estudiante SENA. Especializado en sistemas Android nativos, APIs REST y automatización industrial.',
  ogImage = '/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#05050a" />
    <link rel="canonical" href={canonicalURL} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="John Garcia" />
    <meta name="keywords" content="Full-Stack Developer, Android, Python, FastAPI, React, Kotlin, Ecuador, SENA" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Favicon placeholder -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts: Orbitron + JetBrains Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=JetBrains+Mono:ital,wght@0,300;0,400;0,500;0,700;1,400&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="bg-cyberbg text-white font-mono antialiased overflow-x-hidden">
    <!-- Canvas de fondo: z-0, fixed, pointer-events-none -->
    <CyberBackground />

    <!-- Scanline overlay sutil -->
    <div
      class="pointer-events-none fixed inset-0 z-[1] opacity-[0.02]"
      aria-hidden="true"
      style="background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,240,255,0.15) 2px, rgba(0,240,255,0.15) 4px);"
    ></div>

    <!-- Contenido principal sobre el canvas -->
    <div class="relative z-10">
      <slot />
    </div>
  </body>
</html>

<style is:global>
  /* ── Reset mínimo ─────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; }
  html { font-size: 16px; }

  /* ── Scrollbar Cyberpunk (Webkit) ─────────────── */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: #05050a; }
  ::-webkit-scrollbar-thumb {
    background: #00f0ff;
    border-radius: 0;
    box-shadow: 0 0 8px #00f0ff;
  }
  ::-webkit-scrollbar-thumb:hover { background: #fcee0a; box-shadow: 0 0 8px #fcee0a; }

  /* ── Scrollbar Firefox ────────────────────────── */
  * { scrollbar-width: thin; scrollbar-color: #00f0ff #05050a; }

  /* ── Selección de texto ───────────────────────── */
  ::selection { background: #00f0ff33; color: #00f0ff; }

  /* ── Focus ring accesible ─────────────────────── */
  :focus-visible { outline: 2px solid #00f0ff; outline-offset: 3px; }

  /* ── Utility: texto con glow ──────────────────── */
  .text-glow-cyan    { text-shadow: 0 0 8px #00f0ff, 0 0 20px #00f0ff; }
  .text-glow-magenta { text-shadow: 0 0 8px #ff0055, 0 0 20px #ff0055; }
  .text-glow-yellow  { text-shadow: 0 0 8px #fcee0a, 0 0 20px #fcee0a; }

  /* ── Cyber-cut clip-path ──────────────────────── */
  .cyber-cut {
    clip-path: polygon(
      0 0,
      calc(100% - 16px) 0,
      100% 16px,
      100% 100%,
      16px 100%,
      0 calc(100% - 16px)
    );
  }
  .cyber-cut-sm {
    clip-path: polygon(
      0 0,
      calc(100% - 10px) 0,
      100% 10px,
      100% 100%,
      10px 100%,
      0 calc(100% - 10px)
    );
  }
</style>
